# Strategy
STARTING_BANKROLL=100.0
KELLY_FRACTION=0.5
MIN_EDGE_THRESHOLD=0.03
MAX_EDGE_THRESHOLD=0.08
MIN_BET=1.0

# Telegram notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Endpoints
